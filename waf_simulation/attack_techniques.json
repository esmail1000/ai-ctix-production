        {"id":"XSS-14","name":"innerHTML","example":"element.innerHTML='<script>alert(1)'","covered":true},
        {"id":"XSS-15","name":"localStorage access","example":"localStorage.getItem('token')","covered":true},
        {"id":"XSS-16","name":"SSTI Jinja2","example":"{{7*7}} or {{config.items()}}","covered":true},
