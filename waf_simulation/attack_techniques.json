        {"id":"XSS-20","name":"CSS expression()","example":"style=\"xss:expression(alert(1))\"","covered":true},
        {"id":"XSS-21","name":"HTML entity bypass","example":"&#106;&#97;&#118;&#97;&#115;&#99;&#114;&#105;&#112;&#116;:","covered":true},
        {"id":"XSS-22","name":"DOM-based XSS","example":"location.hash manipulation client-side","covered":false,"note":"Client-side only"},
        {"id":"XSS-23","name":"Mutation XSS (mXSS)","example":"<listing> mutated by browser","covered":false,"note":"Browser-level mutation"}
