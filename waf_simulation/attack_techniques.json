        {"id":"XSS-03","name":"vbscript: protocol","example":"<a href=\"vbscript:msgbox(1)\">","covered":true},
        {"id":"XSS-04","name":"data:text/html","example":"<iframe src=\"data:text/html,<script>alert(1)</script>\">","covered":true},
        {"id":"XSS-05","name":"onload event","example":"<body onload=alert(1)>","covered":true},
        {"id":"XSS-06","name":"onerror event","example":"<img src=x onerror=alert(1)>","covered":true},
        {"id":"XSS-07","name":"Any on* event","example":"<div onmouseenter=alert(1)>","covered":true},
